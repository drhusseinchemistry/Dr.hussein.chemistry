rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Quizzes: Anyone can read, only admins can write/delete
    match /quizzes/{quizId} {
      allow read: if true;
      allow write, delete: if true; 
    }

    // Submissions: Anyone can create, only admins can read/list/delete
    match /submissions/{submissionId} {
      allow create: if true;
      allow read, list, delete: if true; 
    }

    // Settings: Allow read and write for API key management
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
