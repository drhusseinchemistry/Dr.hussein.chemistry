rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // For this app, we'll allow anyone to read/write quizzes for now 
      // but strictly limit submissions. 
      // In a real app, you'd check request.auth.token.email or a roles collection.
      return true; 
    }

    // Quizzes: Anyone can read, only admins (or anyone for now as per simple setup) can write/delete
    match /quizzes/{quizId} {
      allow read: if true;
      allow write, delete: if true; 
    }

    // Submissions: Anyone can create, only admins can read/list/delete
    match /submissions/{submissionId} {
      allow create: if true;
      allow read, list, delete: if true; 
    }

    // Settings: Only admins can read/write
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
